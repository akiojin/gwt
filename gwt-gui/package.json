{
  "name": "gwt-gui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "E2E_COVERAGE=1 playwright test && nyc report --nycrc-path .nycrc.e2e.json && node ../scripts/check-e2e-coverage-threshold.mjs",
    "test:e2e:tauri:windows": "node --test ./e2e-tauri/*.test.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5",
    "@types/dompurify": "^3.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.1",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "selenium-webdriver": "^4.38.0",
    "svelte": "^5",
    "svelte-check": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.3.3",
    "lucide-svelte": "^1.0.1",
    "marked": "^17.0.5"
  }
}
