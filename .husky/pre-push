#!/usr/bin/env sh

set -e

echo "Running CI-equivalent lint checks..."

cargo clippy --all-targets --all-features -- -D warnings
cargo fmt --all -- --check
cargo llvm-cov -p gwt-core -p gwt --all-features --fail-under-lines 90 --ignore-filename-regex 'crates[/\\]gwt[/\\]src[/\\]main\.rs$'
bunx --bun markdownlint-cli . --config .markdownlint.json --ignore target --ignore CHANGELOG.md
pnpm lint:skills

echo "All pre-push checks passed."
