{
  "name": "gwt",
  "version": "8.3.1",
  "private": true,
  "description": "Tauri desktop GUI for Git worktree management and coding agent launch",
  "type": "module",
  "scripts": {
    "dev": "cargo tauri dev",
    "build": "cargo tauri build",
    "test": "cargo test -p gwt-core -p gwt-tauri --all-features",
    "test:frontend": "cd gwt-gui && pnpm test",
    "test:e2e": "cd gwt-gui && pnpm test:e2e",
    "test:all": "bash scripts/test-all.sh",
    "installer:macos": "bash installers/macos/build-installer.sh",
    "installer:windows": "powershell -ExecutionPolicy Bypass -File installers/windows/build-msi.ps1",
    "prepare": "test -n \"$CI\" || bunx husky install",
    "lint:husky": "bash scripts/verify-husky-hooks.sh"
  },
  "keywords": [
    "git",
    "worktree",
    "claude",
    "claude code",
    "codex",
    "gemini",
    "cli",
    "interactive",
    "branch",
    "development",
    "rust"
  ],
  "author": "akiojin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akiojin/gwt.git"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.29.2",
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2"
  }
}
