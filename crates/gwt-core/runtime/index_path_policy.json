{
  "schema_version": 1,
  "max_file_size": 1048576,
  "allow_paths": [
    "tasks/memory.md"
  ],
  "deny_root_prefixes": [
    ".git",
    ".claude",
    ".codex",
    ".gemini",
    ".gwt",
    "tasks",
    "specs"
  ],
  "deny_directory_names": [
    "node_modules",
    "target",
    "dist",
    "build",
    ".next",
    ".nuxt",
    "vendor",
    ".venv",
    "venv",
    ".tox",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    ".gradle",
    ".terraform",
    "coverage",
    "htmlcov",
    ".turbo",
    ".parcel-cache",
    "__pycache__"
  ],
  "deny_file_extensions": [
    ".snap"
  ],
  "binary_extensions": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".bmp",
    ".ico",
    ".svg",
    ".woff",
    ".woff2",
    ".ttf",
    ".eot",
    ".otf",
    ".pdf",
    ".zip",
    ".tar",
    ".gz",
    ".bz2",
    ".xz",
    ".7z",
    ".mp3",
    ".mp4",
    ".wav",
    ".avi",
    ".mov",
    ".mkv",
    ".dmg",
    ".msi",
    ".deb",
    ".rpm",
    ".AppImage",
    ".safetensors",
    ".bin",
    ".onnx",
    ".pt",
    ".pth"
  ]
}
