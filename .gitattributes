# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf
.docker/entrypoint.sh text eol=lf

# Dockerfile should always use LF
Dockerfile text eol=lf
docker-compose.yml text eol=lf
docker-compose.yaml text eol=lf

# Source code files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# SPEC-2359 Phase W-12 Slice 5b (FR-355): the repo-local Work event log is an
# append-only JSONL. Use git's union merge driver so branch divergence keeps
# every recorded event line instead of producing a conflict.
**/.gwt/work/events.jsonl merge=union