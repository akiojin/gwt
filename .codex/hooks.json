{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "GWT_MANAGED_HOOK=runtime-state gwt hook runtime-state PostToolUse",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "GWT_MANAGED_HOOK=runtime-state gwt hook runtime-state PreToolUse",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "gwt hook block-git-branch-ops",
            "type": "command"
          },
          {
            "command": "gwt hook block-cd-command",
            "type": "command"
          },
          {
            "command": "gwt hook block-file-ops",
            "type": "command"
          },
          {
            "command": "gwt hook block-git-dir-override",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "GWT_MANAGED_HOOK=runtime-state gwt hook runtime-state SessionStart",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "GWT_MANAGED_HOOK=runtime-state gwt hook runtime-state Stop",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "GWT_MANAGED_HOOK=runtime-state gwt hook runtime-state UserPromptSubmit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
