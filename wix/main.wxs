<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="GWT"
    Language="1033"
    Version="!(bind.FileVersion.GwtExecutable)"
    Manufacturer="GWT Contributors"
    UpgradeCode="55555555-5555-5555-5555-555555555555">
    <Package
      InstallerVersion="200"
      Compressed="yes"
      InstallScope="perMachine"
      Description="Canvas-based floating terminal GUI for Git Worktree Manager"
      Manufacturer="GWT Contributors" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of GWT is already installed."
      AllowDowngrades="no" />

    <MediaSource Id="1" Cabinet="gwt.cab" EmbedCab="yes" />

    <Feature Id="GwtFeature" Title="GWT" Level="1" AllowAdvertise="no">
      <ComponentRef Id="GwtExecutable" />
      <ComponentRef Id="GwtProgramFilesFolder" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="GWT" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="GWT" />
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="GwtExecutable" Guid="*">
        <File
          Id="GwtExecutable"
          Name="gwt.exe"
          Source="$(var.GWT.TargetDir)\gwt.exe"
          KeyPath="yes">
          <Shortcut
            Id="DesktopShortcut"
            Directory="DesktopFolder"
            Name="GWT"
            WorkingDirectory="INSTALLFOLDER"
            Icon="GwtIcon.ico"
            IconIndex="0"
            Advertise="no" />
        </File>
      </Component>
      <Component Id="GwtProgramFilesFolder" Guid="*">
        <RegistryValue
          Root="HKCU"
          Key="Software\GWT"
          Name="InstallFolder"
          Type="string"
          Value="[INSTALLFOLDER]"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="GWT"
          Description="Canvas-based floating terminal GUI for Git Worktree Manager"
          Target="[INSTALLFOLDER]gwt.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\GWT"
          Name="ShortcutsFolder"
          Type="string"
          Value="[ApplicationProgramsFolder]"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <UIRef Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />
    <WixVariable Id="WixUIDialogBmp" Value="dialog.bmp" />
    <WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />
  </Product>
</Wix>
